#!/usr/bin/python3
# Filter out AMQP requests that match a given regex

import argparse
import configparser
import logging
import os
import re
import sys
import time

import distro_info
import pika


def get_amqp_channel():
    try:
        cp = configparser.ConfigParser()
        with open("/home/ubuntu/rabbitmq.cred") as f:
            cp.read_string("[rabbit]\n" + f.read().replace('"', ""))
        host = cp["rabbit"]["RABBIT_HOST"]
        user = cp["rabbit"]["RABBIT_USER"]
        password = cp["rabbit"]["RABBIT_PASSWORD"]
    except (FileNotFoundError, KeyError):
        host = os.environ["RABBIT_HOST"]
        user = os.environ["RABBIT_USER"]
        password = os.environ["RABBIT_PASSWORD"]
    amqp_con = pika.BlockingConnection(
        parameters=pika.ConnectionParameters(
            host=host,
            credentials=pika.PlainCredentials(
                username=user,
                password=password,
            ),
        ),
    )
    return amqp_con, amqp_con.channel()


def filter_amqp(options, queue_name, regex):
    num_items_deleted = 0
    filter_re = re.compile(regex.encode("UTF-8"), re.DOTALL)

    amqp_con, channel = get_amqp_channel()

    while True:
        try:
            method, _, body = channel.basic_get(queue_name)
        except pika.exceptions.ChannelClosedByBroker:
            logging.warning(f"Queue {queue_name} not found")
            return None
        if body is None:
            logging.info("Message empty, we probably reached the end of the queue")
            break
        if isinstance(body, str):
            body = body.encode("UTF-8")
        logging.debug("queue item: %s (not deleting)", body)
        if options.all_items_in_queue:
            last_search_successful = True
        else:
            last_search_successful = filter_re.search(body)
        if last_search_successful:
            if options.dry_run:
                logging.info("queue item: %s (would delete)", body)
            else:
                logging.info("queue item: %s (deleting)", body)
                channel.basic_ack(method.delivery_tag)
                num_items_deleted += 1
    channel.close()
    amqp_con.close()
    return num_items_deleted


def generate_queue_names():
    udi = distro_info.UbuntuDistroInfo()
    releases = set(udi.supported() + udi.supported_esm())
    prefix = "debci"
    architectures = ["amd64", "arm64", "armhf", "i386", "ppc64el", "s390x"]
    poss_secondaries = ["huge", None]
    queues = []
    for secondary in poss_secondaries:
        for release in releases:
            for arch in architectures:
                if secondary is not None:
                    queue_name = "-".join([prefix, secondary, release, arch])
                else:
                    queue_name = "-".join([prefix, release, arch])
                queues.append(queue_name)
    return queues


def main():
    parser = argparse.ArgumentParser(
        description="""Filter queue based on a regex

This script can be used whenever a new upload happens, obsoleting a previous
one, and that previous upload still had a lot of tests scheduled. To avoid
processing useless jobs, the queue can be filtered on the trigger of the
obsolete upload.

If ~/rabbitmq.cred is not present, this script will load credentials from
$RABBIT_HOST, $RABBIT_USER, and $RABBIT_PASSWORD environment variables.
""",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument(
        "-n",
        "--dry-run",
        default=False,
        action="store_true",
        help="only show the operations that would be performed",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        default=False,
        action="store_true",
        help="additionally show queue items that are not removed",
    )
    parser.add_argument(
        "-a",
        "--all-items-in-queue",
        default=False,
        action="store_true",
        help=(
            "delete all items from specified queue. "
            "When using this option, the provided regex will be ignored."
        ),
    )
    parser.add_argument(
        "queue_name",
        help="The name of the queue to filter. `all` is a valid value.",
    )
    parser.add_argument("regex", help="The regex with which to filter the queue")

    args = parser.parse_args()

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s - %(message)s",
    )

    if args.all_items_in_queue:
        print("""Do you really want to flush this queue? [yN]""", end="")
        sys.stdout.flush()
        response = sys.stdin.readline()
        if not response.strip().lower().startswith("y"):
            print("""Exiting""")
            sys.exit(1)
    queues = [args.queue_name] if args.queue_name != "all" else generate_queue_names()

    for this_queue in queues:
        deletion_count_history = []
        while True:
            num_deleted = filter_amqp(args, this_queue, args.regex)
            if num_deleted is None:
                logging.info("Skipping %s", this_queue)
                break
            deletion_count_history.append(num_deleted)
            if args.dry_run:
                break
            if len(deletion_count_history) >= 5 and all(
                [x == 0 for x in deletion_count_history[-5:]]
            ):
                logging.info(
                    "Finished filtering queue objects, run history:\n{}".format(
                        "\n".join(str(x) for x in deletion_count_history)
                    )
                )
                break
            time.sleep(5)


if __name__ == "__main__":
    main()
