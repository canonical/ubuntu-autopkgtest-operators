#!/bin/sh

set -eu

# $1 expected in form: arch-release-type, with type either "container" or "vm".
IFS=- read -r arch index RELEASE type <<EOF
$1
EOF

export RELEASE

remote="remote-$arch-$index"
imgremote="ubuntu-daily"
base=$RELEASE

if [ -z "${MIRROR-}" ]; then
    echo 'MIRROR environment variable is not set, the image default will be used'
fi

# If $RELEASE is the devel release (or is unknown), and there are no images for
# it, fallback to stable.
stable=$(ubuntu-distro-info --stable) || exit 1
devel=$(ubuntu-distro-info --devel) || devel=UNKNOWN
set -- lxc image info
if [ "$type" = "vm" ]; then
    set -- "$@" --vm
fi
if
    # $RELEASE is devel release or unknown
    ([ "$RELEASE" = "$devel" ] || ubuntu-distro-info --all | { ! grep -q "$RELEASE"; }) &&
    # there are no images for $RELEASE; do not rely on the command generically failing:
    # grep for the specific error string
    "$@" "$imgremote:$base/$arch" 2>&1 | grep -iq "failed.*t be found" &&
    # there are image for stable
    "$@" "$imgremote:$stable/$arch" >/dev/null 2>&1
then
    echo "No $base image appears to be available, falling back to $stable"
    base=$stable
fi

# Construct the autopkgtest-build-lxd command line in $@.
set -- autopkgtest-build-lxd
if [ "$type" = "vm" ]; then
    set -- "$@" --vm
fi
set -- "$@" --remote "$remote" "$imgremote:$base/$arch"

# If RUNTIME_DIRECTORY is set, which normally happens when this script
# is started from the systemd service, then limit to one image build
# per remote.
if [ -d "${RUNTIME_DIRECTORY-}" ]; then
    # Open the lock file on fd 9 and block until the per-remote lock is
    # available. The fd is kept open across the final exec below, so the lock
    # is held for the whole build.
    exec 9>"$RUNTIME_DIRECTORY/$remote.lock"
    flock --verbose 9

    # Lock acquired: tell systemd the build is about to start, so the unit
    # transitions to "running" and RuntimeMaxSec starts counting from here.
    if [ -n "${NOTIFY_SOCKET-}" ]; then
        systemd-notify --ready
    fi
fi

exec "$@"
