#!/usr/bin/python3

import datetime
import json
import subprocess
import sys

MAX_AGE_HOURS = 12
TARGETS_PATH = "/etc/autopkgtest-janitor/targets.conf"


def configured_releases():
    """Read the configured release targets."""
    with open(TARGETS_PATH) as targets_file:
        for line in targets_file:
            name, values = line.strip().split("=", 1)
            if name == "RELEASES":
                return set(values.split())

    raise ValueError(f"RELEASES not found in {TARGETS_PATH}")


def image_target(image):
    """Return the release and architecture for an autopkgtest image."""
    for alias in image["aliases"]:
        parts = alias["name"].split("/")
        if len(parts) in {4, 5} and (len(parts) == 4 or parts[4] == "vm"):
            return alias["name"], parts[2], parts[3]
    return None


def main():
    """Clean stale LXD instances."""
    print(f"Deleting instances older than {MAX_AGE_HOURS} hours")

    now = datetime.datetime.now(datetime.UTC)
    releases = configured_releases()
    remotes = json.loads(subprocess.check_output(["lxc", "remote", "list", "-fjson"]))
    remotes = [r for r in remotes if r.startswith("remote-")]

    errors = False
    for remote in remotes:
        remote_arch = remote.split("-")[1]
        try:
            instances = json.loads(
                subprocess.check_output(["lxc", "list", "-fjson", remote + ":"])
            )
        except Exception as e:
            print(
                f"Error getting list of instances from remote {remote}: {e}",
                file=sys.stderr,
            )
            errors = True
            continue

        for instance in instances:
            created_at = datetime.datetime.fromisoformat(instance["created_at"])
            if now - created_at >= datetime.timedelta(hours=MAX_AGE_HOURS):
                print(f"Instance {remote}:{instance['name']} is old - deleting")
                try:
                    subprocess.check_call(
                        [
                            "lxc",
                            "delete",
                            "--force",
                            f"{remote}:{instance['name']}",
                        ],
                        timeout=60,
                    )
                except subprocess.CalledProcessError as e:
                    print(
                        f"Error deleting {remote}:{instance['name']}: {e}",
                        file=sys.stderr,
                    )
                    errors = True
                    continue
                except subprocess.TimeoutExpired as e:
                    print(
                        f"Timeout deleting {remote}:{instance['name']}: {e}",
                        file=sys.stderr,
                    )
                    errors = True
                    continue

        try:
            images = json.loads(
                subprocess.check_output(
                    [
                        "lxc",
                        "image",
                        "list",
                        "-fjson",
                        remote + ":autopkgtest/ubuntu/",
                    ]
                )
            )
        except Exception as e:
            print(
                f"Error getting list of images from remote {remote}: {e}",
                file=sys.stderr,
            )
            errors = True
            continue

        for image in images:
            target = image_target(image)
            if not target:
                continue
            alias, release, arch = target
            if arch != remote_arch or release in releases:
                continue

            print(f"Image {remote}:{alias} is not a configured target - deleting")
            try:
                subprocess.check_call(
                    ["lxc", "image", "delete", f"{remote}:{alias}"],
                    timeout=60,
                )
            except subprocess.CalledProcessError as e:
                print(
                    f"Error deleting {remote}:{alias}: {e}",
                    file=sys.stderr,
                )
                errors = True
                continue
            except subprocess.TimeoutExpired as e:
                print(
                    f"Timeout deleting {remote}:{alias}: {e}",
                    file=sys.stderr,
                )
                errors = True
                continue

    if errors:
        print(
            "Errors encountered during cleanup, see messages above",
            file=sys.stderr,
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
