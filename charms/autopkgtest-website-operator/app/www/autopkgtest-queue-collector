#!/usr/bin/python3
# Read all queues, drop duplicate/invalid messages, and write them to queues.json

import json
import logging
import os
import tempfile

from helpers.utils import amqp_connect, get_autopkgtest_cloud_conf, get_release_arches
from pika.exceptions import AMQPError

AMQP_CONTEXTS = ["ubuntu", "huge", "ppa", "upstream"]

logger = logging.getLogger("autopkgtest-queue-collector")
logger.setLevel(logging.INFO)


class AutopkgtestQueueContents:
    def __init__(self, amqp_conn):
        assert amqp_conn is not None

        self.amqp_conn = amqp_conn

    @staticmethod
    def request_unique_key(body):
        """Return a stable deduplication key for an AMQP request."""
        package, params = body.split("\n", 1)
        params = json.loads(params)
        params.pop("submit-time", None)
        return package, json.dumps(params, sort_keys=True)

    def get_queue_requests(self, queue_name):
        """Return list of pending requests in AMQP queue."""
        requests = []
        seen = set()
        channel = self.amqp_conn.channel()

        # Read the queue without acking unique requests; closing the channel will
        # put them back. Invalid and duplicate requests are acked, which drops them.
        while True:
            method, _, body = channel.basic_get(queue_name)
            if body is None:
                break

            try:
                if isinstance(body, bytes):
                    body = body.decode("UTF-8")
                key = self.request_unique_key(body)
            except (
                UnicodeDecodeError,
                ValueError,
                IndexError,
                TypeError,
                AttributeError,
            ) as e:
                logger.warning(f"Received invalid request {body}: {repr(e)}")
                channel.basic_ack(delivery_tag=method.delivery_tag)
                continue
            else:
                if key in seen:
                    logger.info(f"Dropping duplicate request from {queue_name}: {key}")
                    channel.basic_ack(delivery_tag=method.delivery_tag)
                    continue
                seen.add(key)

            requests.append(body)
            logger.debug(f"{queue_name}: name {body}")

        # closing the channel will put all the messages back to the queue
        channel.close()

        res = []
        for r in requests:
            params = r.split("\n", 1)[1]
            params = json.loads(params)
            if params.get("readable-by", False) or params.get("swiftuser", False):
                r = "private job"
            res.append(r)

        return res

    def get_queue_contents(self):
        """Get queue contents from AMQP and cache them on disk."""
        release_arches = get_release_arches()
        all_arches = set()

        result = {}
        for context in AMQP_CONTEXTS:
            for release, arches in release_arches.items():
                for arch in arches:
                    if context != "ubuntu":
                        queue_name = f"debci-{context}-{release}-{arch}"
                    else:
                        # ubuntu test requests use context-less name (backwards compatibility)
                        queue_name = f"debci-{release}-{arch}"
                    try:
                        requests = self.get_queue_requests(queue_name)
                    except AMQPError:
                        logger.warning(f"Failed reading data from queue {queue_name}")
                        continue
                    queue_size = 0
                    if requests:
                        queue_size = len(requests)
                    logger.info(f"queue {queue_name} has {queue_size} items")
                    result.setdefault(context, {}).setdefault(release, {})[arch] = {
                        "size": queue_size,
                        "requests": requests,
                    }
                    all_arches.add(arch)

        queued = {
            "releases": list(release_arches.keys()),
            "arches": sorted(all_arches),
            "queues": result,
        }

        return queued


if __name__ == "__main__":
    cp = get_autopkgtest_cloud_conf()

    amqp_conn = amqp_connect()
    logger.info("Connected to AMQP")

    queues_file = cp["web"]["amqp_queue_cache"]

    aq = AutopkgtestQueueContents(amqp_conn)
    queue_contents = aq.get_queue_contents()

    with tempfile.NamedTemporaryFile(
        mode="w",
        dir=os.path.dirname(queues_file),
        suffix=".json",
        delete_on_close=False,
    ) as tf:
        json.dump(queue_contents, tf, indent=2)
        tf.close()
        os.rename(tf.name, queues_file)

    amqp_conn.close()
